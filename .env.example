NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Admin dashboard
NEXT_PUBLIC_ADMIN_EMAIL=your_admin_email@gmail.com

# Cloudinary (server-side only — never use NEXT_PUBLIC_ for API_SECRET)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# RAG / AI Chat
JINA_API_KEY=              # https://jina.ai → free API key (10M tokens)
OPENROUTER_API_KEY=        # https://openrouter.ai → free account
OPENROUTER_MODEL=          # optional override, default: nvidia/nemotron-3-super-120b-a12b:free
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1

# S3 — regular bucket for storing original PDF files
S3_BUCKET_NAME=

# S3 Vectors — vector bucket + HNSW index for ANN similarity search (dimension=1024, cosine)
S3_VECTOR_BUCKET_NAME=
S3_VECTOR_INDEX_NAME=portfolio-knowledge